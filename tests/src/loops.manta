mod main

fn main() i64 {
    let a = 0
    let b = true
    loop {
        if b {
            b = false
            continue
        }

        a = a + 1

        if a > 255 {
            break

            return 0
        }

        loop {
            loop {
                break
            }
            break
        }
    }

    let c = true
    let d = 3.1415
    while c {
        d = d + 3.1415

        if d > 30 {
            c = false
        }
    }

    return a
}
